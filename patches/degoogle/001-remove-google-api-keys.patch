-// google.com/search, google.com/webhp, translate.google.com, etc.
-// All Google-specific URL routing is disabled.
-
-// DuckDuckGo search URL handler (see search/ directory for config)
+// Ember Browser: Google URL handlers removed.
+// DuckDuckGo search is configured via search/ patches.
diff --git a/chrome/browser/google_url_tracker.cc b/chrome/browser/google_url_tracker.cc
index abc1234..def5678 100644
--- a/chrome/browser/google_url_tracker.cc
+++ b/chrome/browser/google_url_tracker.cc
@@ -1,3 +1,3 @@
-// EMBER: Google URL tracker disabled
-// This component tracks whether the user has visited a Google URL.
-// Removed to eliminate all Google tracking behavior.
