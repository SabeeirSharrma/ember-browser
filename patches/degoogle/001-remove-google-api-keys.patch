+// Ember Browser: Google service URLs stripped.
+// Only internal chrome:// URLs retained for Ember Shell integration.
diff --git a/chrome/common/google_chrome_url_handlers.cc b/chrome/common/google_chrome_url_handlers.cc
index abc1234..def5678 100644
--- a/chrome/common/google_chrome_url_handlers.cc
