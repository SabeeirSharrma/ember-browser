-// EMBER: Google service URLs removed
-const char kChromeWebStoreURL[] = "";
-const char kGoogleUpdateURL[] = "";
-const char kGoogleSafeBrowsingURL[] = "";
-const char kGoogleAccountURL[] = "";
-const char kSyncURL[] = "";
