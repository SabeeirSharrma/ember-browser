 // found in the LICENSE file.
 
 #include "components/google/core/common/google_api_keys.h"
 
-#include "base/environment.h"
-#include "base/logging.h"
-#include "build/build_config.h"
-
 namespace google {
 
-// Default API keys - EMBER: All keys removed
-// These are intentionally left empty to prevent any Google service connections.
+// Ember Browser: All Google API keys removed.
+// No Google services should be contacted by this build.
 const char kGoogleApiKey[] = "";
-const char kGoogleApiKeyClientId[] = "";
-const char kGoogleApiKeyClientSecret[] = "";
-
-// ... (additional key removals)
+const char kOAuthClientID[] = "";
+const char kOAuthClientSecret[] = "";
 
 }  // namespace google
diff --git a/chrome/common/chrome_constants.cc b/chrome/common/chrome_constants.cc
